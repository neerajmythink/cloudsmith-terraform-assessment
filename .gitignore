# terraform files to be ignored by git
# Ignore Terraform state files
*.tfstate
*.tfstate.backup
# Ignore Terraform variables files that may contain sensitive information
*.tfvars
# Ignore crash logs from Terraform
crash.log
# Ignore .terraform directory which contains plugins and modules
.terraform/
# Ignore .terraform.lock.hcl which contains provider dependency information
.terraform.lock.hcl
# Ignore any files that may contain sensitive information
*.pem
*.key
*.crt
*.env
# Ignore any files that may contain API keys or secrets
*.secret
*.api_key   
*.credentials
# Ignore any files that may contain logs or debug information
*.log
*.debug
# Ignore any files that may contain local overrides or custom configurations
*.override.tf
*.local.tf  
# Ignore any files that may contain backup or temporary data
*.bak
*.tmp
*.backup
